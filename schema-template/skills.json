{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "skills.json",
	"version": "1.1.0",
	"type": "object",
	"$defs": {
		"skillData": {
			"type": "object",
			"properties": {
				"name": {"type": "string"},
				"source": {"$ref": "util.json#/$defs/source"},
				"page": {"$ref": "util.json#/$defs/page"},
				"$$ifSite": {
					"srd": {"$ref": "util.json#/$defs/srd"},
					"srd52": {"$ref": "util.json#/$defs/srd"},
					"basicRules": {"$ref": "util.json#/$defs/basicRules"},
					"basicRules2024": {"$ref": "util.json#/$defs/basicRules"}
				},
				"reprintedAs": {"$ref": "util.json#/$defs/reprintedAs"},
				"ability": {"$ref": "util.json#/$defs/abilityScoreAbbreviation"},
				"entries": {
					"type": "array",
					"items": {
						"$ref": "entry.json"
					}
				}
			},
			"additionalProperties": false
		},

		"skill": {
			"anyOf": [
				{
					"type": "object",
					"$$merge": [
						{
							"$ref": "#/$defs/skillData"
						},
						{
							"required": ["name", "source", "entries"]
						}
					]
				},
				{
					"type": "object",
					"$$merge": [
						{
							"$ref": "#/$defs/skillData"
						},
						{
							"$ref": "util-copy.json#/$defs/copyBlockGeneric"
						}
					]
				}
			]
		}
	},

	"properties": {
		"_meta": {"$ref": "util.json#/$defs/metaBlock"},
		"skill": {
			"type": "array",
			"minItems": 1,
			"uniqueItems": true,
			"items": {
				"$ref": "#/$defs/skill"
			}
		}
	},
	"required": ["skill"],
	"additionalProperties": false
}
