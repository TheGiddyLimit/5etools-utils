{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "charcreationoptions.json",
	"version": "1.3.0",
	"title": "Character Creation Options",
	"type": "object",
	"$defs": {
		"optionType": {
			"type": "string",
			"description": "- CS: Character Secret\n- DG: Dark Gift\n- OF: Optional Feature\n- PTH: Path\n- RF:B Replacement Feature: Background\n- SG: Supernatural Gift",
			"markdownDescription": "- CS: Character Secret\n- DG: Dark Gift\n- OF: Optional Feature\n- PTH: Path\n- RF:B Replacement Feature: Background\n- SG: Supernatural Gift",
			"enum": [
				"CS",
				"DG",
				"OF",
				"PTH",
				"RF:B",
				"SG"
			]
		},
		"charoptionData": {
			"type": "object",
			"properties": {
				"name": {
					"type": "string"
				},
				"entries": {
					"type": "array",
					"items": {
						"$ref": "entry.json"
					}
				},
				"source": {
					"$ref": "util.json#/$defs/source"
				},
				"page": {
					"$ref": "util.json#/$defs/page"
				},
				"optionType": {
					"$comment": "Note that this field supports arbitrary strings for homebrew usage.",
					"type": "array",
					"items": {
						"$ref": "#/$defs/optionType"
					}
				},
				"otherSources": {
					"$ref": "util.json#/$defs/otherSources"
				},
				"referenceSources": {
					"$ref": "util.json#/$defs/referenceSources"
				},
				"hasFluff": {
					"type": "boolean"
				},
				"hasFluffImages": {
					"type": "boolean"
				},
				"prerequisite": {
					"$ref": "util.json#/$defs/prerequisite"
				}
			},
			"additionalProperties": false
		},
		"charoption": {
			"anyOf": [
				{
					"type": "object",
					"properties": {
						"name": {
							"type": "string"
						},
						"entries": {
							"type": "array",
							"items": {
								"$ref": "entry.json"
							}
						},
						"source": {
							"$ref": "util.json#/$defs/source"
						},
						"page": {
							"$ref": "util.json#/$defs/page"
						},
						"optionType": {
							"$comment": "Note that this field supports arbitrary strings for homebrew usage.",
							"type": "array",
							"items": {
								"$ref": "#/$defs/optionType"
							}
						},
						"otherSources": {
							"$ref": "util.json#/$defs/otherSources"
						},
						"referenceSources": {
							"$ref": "util.json#/$defs/referenceSources"
						},
						"hasFluff": {
							"type": "boolean"
						},
						"hasFluffImages": {
							"type": "boolean"
						},
						"prerequisite": {
							"$ref": "util.json#/$defs/prerequisite"
						}
					},
					"additionalProperties": false,
					"required": [
						"name",
						"source",
						"entries",
						"optionType"
					]
				},
				{
					"type": "object",
					"properties": {
						"name": {
							"type": "string"
						},
						"entries": {
							"type": "array",
							"items": {
								"$ref": "entry.json"
							}
						},
						"source": {
							"$ref": "util.json#/$defs/source"
						},
						"page": {
							"$ref": "util.json#/$defs/page"
						},
						"optionType": {
							"$comment": "Note that this field supports arbitrary strings for homebrew usage.",
							"type": "array",
							"items": {
								"$ref": "#/$defs/optionType"
							}
						},
						"otherSources": {
							"$ref": "util.json#/$defs/otherSources"
						},
						"referenceSources": {
							"$ref": "util.json#/$defs/referenceSources"
						},
						"hasFluff": {
							"type": "boolean"
						},
						"hasFluffImages": {
							"type": "boolean"
						},
						"prerequisite": {
							"$ref": "util.json#/$defs/prerequisite"
						},
						"_copy": {
							"$ref": "util-copy.json#/$defs/copyBlock_copy_generic"
						}
					},
					"additionalProperties": false,
					"required": [
						"_copy"
					]
				}
			]
		}
	},
	"properties": {
		"_meta": {
			"$ref": "util.json#/$defs/metaBlock"
		},
		"charoption": {
			"type": "array",
			"minItems": 1,
			"uniqueItems": true,
			"items": {
				"$ref": "#/$defs/charoption"
			}
		}
	},
	"required": [
		"charoption"
	],
	"additionalProperties": false
}