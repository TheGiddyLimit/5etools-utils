							"$ref": "util.json#/$defs/reprintedAs"
						},
						"type": {
							"type": "string",
							"enum": [
								"Blessing",
								"Boon",
								"Charm",
								"Curse",
								"Draconic Gift",
								"Inhabitation",
								"Fragment of Suffering",
								"Other",
								"Piety Trait"
