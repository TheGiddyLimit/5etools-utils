						"additionalSpells": {
							"$ref": "util-additionalspells.json#/$defs/additionalSpellsArray"
						},
						"entries": {
							"type": "array",
							"uniqueItems": true,
							"items": {
								"$ref": "entry.json"
							}
						},
						"hasFluff": {
							"type": "boolean"
						},
						"hasFluffImages": {
							"type": "boolean"
						}
					},
					"additionalProperties": false,
