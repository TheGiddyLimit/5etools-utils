						"Boon",
						"Charm",
						"Curse",
						"Draconic Gift",
						"Inhabitation",
						"Fragment of Suffering",
						"Other",
						"Piety Trait"
					]
				},
				"ability": {
					"type": "object",
					"properties": {
						"entry": {
							"$ref": "entry.json"
						}
					},
					"required": [
						"entry"
					],
					"additionalProperties": false
				},
				"rarity": {
					"$ref": "util.json#/$defs/rarity"
				},
				"additionalSpells": {
					"$ref": "util-additionalspells.json#/$defs/additionalSpellsArray"
