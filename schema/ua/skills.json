{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "skills.json",
	"version": "1.1.0",
	"type": "object",
	"$defs": {
		"skillData": {
			"type": "object",
			"properties": {
				"name": {
					"type": "string"
				},
				"source": {
					"$ref": "util.json#/$defs/source"
				},
				"page": {
					"$ref": "util.json#/$defs/page"
				},
				"reprintedAs": {
					"$ref": "util.json#/$defs/reprintedAs"
				},
				"ability": {
					"$ref": "util.json#/$defs/abilityScoreAbbreviation"
				},
				"entries": {
					"type": "array",
					"items": {
						"$ref": "entry.json"
					}
				}
			},
			"additionalProperties": false
		},
		"skill": {
			"anyOf": [
				{
					"type": "object",
					"properties": {
						"name": {
							"type": "string"
						},
						"source": {
							"$ref": "util.json#/$defs/source"
						},
						"page": {
							"$ref": "util.json#/$defs/page"
						},
						"reprintedAs": {
							"$ref": "util.json#/$defs/reprintedAs"
						},
						"ability": {
							"$ref": "util.json#/$defs/abilityScoreAbbreviation"
						},
						"entries": {
							"type": "array",
							"items": {
								"$ref": "entry.json"
							}
						}
					},
					"additionalProperties": false,
					"required": [
						"name",
						"source",
						"entries"
					]
				},
				{
					"type": "object",
					"properties": {
						"name": {
							"type": "string"
						},
						"source": {
							"$ref": "util.json#/$defs/source"
						},
						"page": {
							"$ref": "util.json#/$defs/page"
						},
						"reprintedAs": {
							"$ref": "util.json#/$defs/reprintedAs"
						},
						"ability": {
							"$ref": "util.json#/$defs/abilityScoreAbbreviation"
						},
						"entries": {
							"type": "array",
							"items": {
								"$ref": "entry.json"
							}
						},
						"_copy": {
							"$ref": "util-copy.json#/$defs/copyBlock_copy_generic"
						}
					},
					"additionalProperties": false,
					"required": [
						"_copy"
					]
				}
			]
		}
	},
	"properties": {
		"_meta": {
			"$ref": "util.json#/$defs/metaBlock"
		},
		"skill": {
			"type": "array",
			"minItems": 1,
			"uniqueItems": true,
			"items": {
				"$ref": "#/$defs/skill"
			}
		}
	},
	"required": [
		"skill"
	],
	"additionalProperties": false
}